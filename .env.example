# YouTube Data API v3
# Get free key: https://console.cloud.google.com → Enable "YouTube Data API v3" → Create credentials → API Key
YOUTUBE_API_KEY=your_youtube_api_key_here
# Twitch Helix API
# Get free credentials: https://dev.twitch.tv/console → Register Your Application
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# Backend
PORT=3001
NODE_ENV=development
DB_PATH=./data/hardscope.db

# Frontend (Vite)
VITE_API_URL=http://localhost:3001
